<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by Electron + Node on hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for some native modules that dlopen at runtime -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Required for electron-updater to swap the bundle in place -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Disk access so the user can pick any vault folder -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Network access so plugins can http.fetch allowlisted domains + auto-update + Sentry -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
